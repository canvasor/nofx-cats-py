# Runtime
CATS_ENV=dev
CATS_MODE=shadow
CATS_LOG_LEVEL=INFO

# NOFX
NOFX_API_KEY=replace_me
NOFX_AUTH_MODE=bearer
NOFX_BASE_URL=https://nofxos.ai

# Binance REST / WS
BINANCE_API_KEY=replace_me
BINANCE_API_SECRET=replace_me
BINANCE_REST_BASE_URL=https://fapi.binance.com
BINANCE_WS_PUBLIC_URL=wss://fstream.binance.com/public
BINANCE_WS_MARKET_URL=wss://fstream.binance.com/market
BINANCE_WS_PRIVATE_URL=wss://fstream.binance.com/private

# Storage
POSTGRES_DSN=postgresql://cats:cats@localhost:5432/cats
REDIS_URL=redis://localhost:6379/0
CLICKHOUSE_DSN=http://default:@localhost:8123/default

# App config
CATS_APP_CONFIG=configs/app.yaml
CATS_RISK_CONFIG=configs/risk.yaml
CATS_SYMBOLS_CONFIG=configs/symbols.yaml
